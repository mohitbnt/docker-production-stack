#####################################
# PostgreSQL
#####################################

POSTGRES_DB=opsportal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

#####################################
# Flask
#####################################

FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=replace_with_secure_key

#####################################
# Redis
#####################################

REDIS_HOST=redis
REDIS_PORT=6379

#####################################
# Application
#####################################

APP_PORT=5000

#####################################
# Nginx
#####################################

NGINX_PORT=80

#####################################
# Monitoring
#####################################

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000