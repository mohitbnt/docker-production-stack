APP_ENV=${ENVIRONMENT_NAME:-dev}
APP_NAME=opsportal
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_LOG_DIR=/var/log/opsportal

FLASK_APP=wsgi:app
FLASK_DEBUG=0
SECRET_KEY=${SECRET_KEY:-change-me}

JWT_SECRET_KEY=${JWT_SECRET_KEY:-change-me}
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ALGORITHM=HS256

POSTGRES_DB=${POSTGRES_DB:-opsportal}
POSTGRES_USER=${POSTGRES_USER:-opsportal}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-opsportal_pw}
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=60

CORS_ORIGINS=http://localhost,http://127.0.0.1

SEED_ADMIN_EMAIL=${SEED_ADMIN_EMAIL:-admin@opsportal.local}
SEED_ADMIN_PASSWORD=${SEED_ADMIN_PASSWORD:-admin123}
SEED_ADMIN_NAME="System Administrator"

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60